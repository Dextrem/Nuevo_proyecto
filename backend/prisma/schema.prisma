generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  CARD
  CREDIT
  TRANSFER
}

enum CashTransactionType {
  INCOME
  EXPENSE
}

model User {
  id                     String    @id @default(uuid())
  username               String    @unique
  email                  String    @unique
  password               String
  name                   String
  role                   Role      @default(CASHIER)
  permissions            Json      @default("{}")
  active                 Boolean   @default(true)
  failedLoginAttempts    Int       @default(0)
  lockUntil              DateTime?
  lastLoginAttempt       DateTime?
  lastPasswordChange     DateTime  @default(now())
  passwordExpiresAt      DateTime?
  passwordNeverExpires   Boolean   @default(false)
  passwordExpirationDays Int       @default(90)
  mustChangePassword     Boolean   @default(false)
  tokenVersion           Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  sales              Sale[]
  quotations         Quotation[]
  transactions       Transaction[]
  openedRegisters    CashRegister[]      @relation("CashRegisterOpenedBy")
  closedRegisters    CashRegister[]      @relation("CashRegisterClosedBy")
  cashTransactions   CashTransaction[]
  commissions        Commission[]
  purchaseOrders     PurchaseOrder[]
  inventoryMovements InventoryMovement[]
  warranties         Warranty[]

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  sku         String   @unique
  barcode     String?  @unique
  price       Float
  cost        Float    @default(0)
  stock       Int      @default(0)
  minStock    Int      @default(0)
  categoryId  String?
  active      Boolean  @default(true)
  imageUrl    String? // URL de la imagen del producto
  imagePath   String? // Ruta local de la imagen (para servir estáticamente)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category           Category?           @relation(fields: [categoryId], references: [id])
  saleItems          SaleItem[]
  quotationItems     QuotationItem[]
  CostAnalysis       CostAnalysis[]
  purchaseOrderItems PurchaseOrderItem[]
  inventoryMovements InventoryMovement[]

  @@index([name])
  @@index([categoryId])
  @@index([active])
  @@map("products")
}

model Client {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  rnc         String?
  address     String?
  balance     Float    @default(0)
  creditLimit Float    @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sales             Sale[]
  quotations        Quotation[]
  AccountReceivable AccountReceivable[]
  PendingPayment    PendingPayment[]
  warranties        Warranty[]

  @@index([name])
  @@index([active])
  @@map("clients")
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  rnc       String?
  address   String?
  contact   String?
  balance   Float    @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices       SupplierInvoice[]
  AccountPayable AccountPayable[]
  purchaseOrders PurchaseOrder[]

  @@index([name])
  @@index([active])
  @@map("suppliers")
}

model SupplierInvoice {
  id            String    @id @default(uuid())
  invoiceNumber String?
  description   String
  amount        Float
  dueDate       DateTime?
  paid          Boolean   @default(false)
  paidAmount    Float     @default(0)
  paidDate      DateTime?
  document      String?
  documentName  String?
  notes         String?
  supplierId    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  supplier       Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([supplierId])
  @@index([paid])
  @@index([dueDate])
  @@map("supplier_invoices")
}

model Sale {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  subtotal       Float
  tax            Float
  discount       Float         @default(0)
  shippingCost   Float         @default(0)
  interest       Float         @default(0)
  total          Float
  paidAmount     Float
  change         Float         @default(0)
  paymentMethod  PaymentMethod
  dueDate        DateTime?
  saleDate       DateTime      @default(now())
  status         String        @default("COMPLETED")
  printCount     Int           @default(0)
  clientId       String?
  userId         String
  cashRegisterId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client            Client?             @relation(fields: [clientId], references: [id])
  user              User                @relation(fields: [userId], references: [id])
  items             SaleItem[]
  AccountReceivable AccountReceivable[]

  // Warranty fields
  hasWarranty  Boolean @default(false)
  warrantyData Json?
  warranty     Warranty?

  // DGII Fiscal fields
  ncf     String?
  ncfType String?

  @@index([clientId])
  @@index([saleDate])
  @@index([status])
  @@map("sales")
}

model FiscalSequence {
  id          String   @id @default(uuid())
  type        String   @unique // e.g., "01", "02", "14", "15"
  name        String // e.g., "Crédito Fiscal", "Consumidor Final"
  prefix      String   @default("B")
  current     Int      @default(1)
  limit       Int
  active      Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("fiscal_sequences")
}

model SaleItem {
  id        String @id @default(uuid())
  quantity  Int
  price     Float
  cost      Float  @default(0)
  tax       Float
  discount        Float      @default(0)
  shippingCost    Float      @default(0)
  total           Float
  saleId    String
  productId String

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([saleId])
  @@map("sale_items")
}

model Quotation {
  id              String   @id @default(uuid())
  quotationNumber String   @unique
  subtotal        Float
  tax             Float
  discount        Float    @default(0)
  total           Float
  notes           String?
  validityDays    Int      @default(30)
  status          String   @default("PENDING")
  clientId        String?
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientName    String?
  clientRnc     String?
  clientPhone   String?
  clientAddress String?
  clientEmail   String?
  paymentMethod String?
  deliveryTime  String?
  warranty      String?

  client Client?         @relation(fields: [clientId], references: [id])
  user   User            @relation(fields: [userId], references: [id])
  items  QuotationItem[]

  @@index([clientId])
  @@index([status])
  @@index([userId])
  @@map("quotations")
}

model QuotationItem {
  id          String @id @default(uuid())
  quantity    Int
  price       Float
  tax         Float
  discount    Float  @default(0)
  total       Float
  quotationId String
  productId   String

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@index([quotationId])
  @@index([productId])
  @@map("quotation_items")
}

model Transaction {
  id          String          @id @default(uuid())
  type        TransactionType
  amount      Float
  description String
  reference   String?
  date        DateTime        @default(now())
  userId      String
  category    String?
  status      String          @default("APPROVED")
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([date])
  @@index([status])
  @@index([userId])
  @@index([category])
  @@map("transactions")
}

model Settings {
  id             String  @id @default(uuid())
  companyName    String  @default("Mi Empresa")
  companyRnc     String?
  companyAddress String?
  companyPhone   String?
  companyEmail   String?
  logo           String?
  currency       String  @default("DOP")
  currencySymbol String  @default("$")
  taxRate        Float   @default(0.18)
  interestRate   Float   @default(0.02)
  theme          String  @default("light")
  primaryColor   String  @default("#4F46E5")

  // Commission Settings
  commissionRate      Float  @default(0.15)
  commissionMinAmount Float  @default(4000)
  commissionType      String @default("BY_SALE") // BY_SALE or ACCUMULATED

  // Security Settings
  sessionTimeoutMinutes  Int @default(30)
  maxLoginAttempts       Int @default(5)
  lockoutDurationMinutes Int @default(15)
  defaultPasswordExpDays Int @default(90)

  // POS / Sales Settings
  defaultCreditLimit   Float   @default(5000)
  allowNegativeStock   Boolean @default(false)
  receiptFooterMessage String?
  requireCashRegister  Boolean @default(true)

  // Inventory Settings
  lowStockAlertEnabled Boolean @default(true)
  defaultMinStock      Int     @default(5)

  // Fiscal Settings (NCF / DGII)
  fiscalEnabled  Boolean @default(false)
  defaultNcfType String  @default("02")

  // Warranty Settings
  warrantyEnabled      Boolean @default(true)
  warrantyMinAmount    Float   @default(2000)
  warrantyDefaultDays  Int     @default(90)
  warrantyCoverageText String?
  warrantyExclusionText String?

  updatedAt DateTime @updatedAt

  @@map("settings")
}

model CashRegister {
  id            String    @id @default(uuid())
  name          String
  isOpen        Boolean   @default(false)
  openingAmount Float     @default(0)
  currentAmount Float     @default(0)
  closingAmount Float?
  openedAt      DateTime?
  closedAt      DateTime?
  openedBy      String
  closedBy      String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  openedByUser User              @relation("CashRegisterOpenedBy", fields: [openedBy], references: [id])
  closedByUser User?             @relation("CashRegisterClosedBy", fields: [closedBy], references: [id])
  transactions CashTransaction[]

  @@map("cash_registers")
}

model CashTransaction {
  id             String              @id @default(uuid())
  type           CashTransactionType
  amount         Float
  description    String
  reference      String?
  date           DateTime            @default(now())
  cashRegisterId String
  userId         String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([cashRegisterId])
  @@index([type])
  @@index([userId])
  @@index([date])
  @@map("cash_transactions")
}

model Budget {
  id            String   @id @default(uuid())
  category      String
  type          String   @default("expense")
  plannedAmount Float
  year          Int
  month         Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([category, year, month])
  @@map("budgets")
}

model TransactionHistory {
  id           String   @id @default(uuid())
  date         DateTime @default(now())
  type         String
  description  String?
  amount       Float
  category     String?
  categoryName String?
  reference    String?
  clientName   String?
  supplierName String?
  userName     String?
  details      Json?
  createdAt    DateTime @default(now())

  @@index([type])
  @@index([categoryName])
  @@index([date])
  @@index([reference])
  @@map("transactions_history")
}

model AccountReceivable {
  id          String    @id @default(uuid())
  clientId    String
  saleId      String?
  description String?
  amount      Float
  paidAmount  Float     @default(0)
  dueDate     DateTime?
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id])
  sale   Sale?  @relation(fields: [saleId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@map("accounts_receivable")
}

model AccountPayable {
  id            String    @id @default(uuid())
  supplierId    String
  invoiceNumber String?
  description   String?
  amount        Float
  paidAmount    Float     @default(0)
  dueDate       DateTime?
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([status])
  @@index([dueDate])
  @@map("accounts_payable")
}

model CostAnalysis {
  id          String   @id @default(uuid())
  productId   String?
  category    String?
  period      String
  periodYear  Int
  periodMonth Int
  costAmount  Float
  revenue     Float
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product? @relation(fields: [productId], references: [id])

  @@map("cost_analysis")
}

model MonthlyClosing {
  id                      String   @id @default(uuid())
  year                    Int
  month                   Int
  startDate               DateTime
  endDate                 DateTime
  totalIncome             Float    @default(0)
  totalExpense            Float    @default(0)
  netBalance              Float    @default(0)
  totalSales              Float    @default(0)
  totalPurchases          Float    @default(0)
  totalAccountsReceivable Float    @default(0)
  totalAccountsPayable    Float    @default(0)
  cashInRegister          Float    @default(0)
  totalProductsSold       Int      @default(0)
  transactionCount        Int      @default(0)
  salesCount              Int      @default(0)
  expensesByCategory      Json     @default("{}")
  status                  String   @default("CLOSED")
  notes                   String?
  closedBy                String
  closedAt                DateTime @default(now())
  createdAt               DateTime @default(now())

  // Extended Financial Analysis Fields
  accountsReceivableDetails Json? // CxC: { current: 0, aging30: 0, aging60: 0, aging90: 0, overdue: 0, provision: 0 }
  accountsPayableDetails    Json? // CxP: { suppliers: 0, financial: 0, accrued: 0, overdue: 0 }
  incomeDetails             Json? // { interest: 0, commissions: 0, other: 0 }
  expenseDetails            Json? // { operational: 0, administrative: 0, financial: 0, depreciation: 0 }
  bankReconciliation        Json? // { totalDeposits: 0, totalWithdrawals: 0, reconciled: 0, pending: 0, differences: 0 }
  financialIndicators       Json? // { profitability: 0, liquidity: 0, leverage: 0, portfolioQuality: 0 }
  executiveSummary          Json? // { keyFindings: [], risks: [], recommendations: [], generalStatus: "" }
  accountingEntries         Json? // Detailed accounting entries log
  closingValidations        Json? // Validations: { cxcMatch: true, cxpMatch: true, bankMatch: true }

  @@unique([year, month])
  @@index([year, month])
  @@index([status])
  @@map("monthly_closings")
}

model Commission {
  id               String    @id @default(uuid())
  userId           String
  periodStart      DateTime
  periodEnd        DateTime
  totalSales       Float     @default(0)
  commissionRate   Float     @default(0.15)
  commissionAmount Float     @default(0)
  status           String    @default("PENDING") // PENDING, APPROVED, PAID
  calculationType  String    @default("BY_SALE")
  details          Json?
  calculatedAt     DateTime  @default(now())
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([periodStart])
  @@index([status])
  @@map("commissions")
}

model PurchaseOrder {
  id          String    @id @default(uuid())
  orderNumber String    @unique
  supplierId  String
  status      String    @default("PENDING") // PENDING, RECEIVED, CANCELLED
  totalAmount Float
  notes       String?
  userId      String
  receivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  user      User                @relation(fields: [userId], references: [id])
  items     PurchaseOrderItem[]
  invoiceId String?
  invoice   SupplierInvoice?    @relation(fields: [invoiceId], references: [id])

  @@index([supplierId])
  @@index([status])
  @@index([userId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitCost        Float
  total           Float

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model InventoryMovement {
  id            String   @id @default(uuid())
  productId     String
  type          String // 'IN' (compras/ajustes), 'OUT' (ventas/mermas)
  quantity      Int
  previousStock Int
  newStock      Int
  reference     String? // Factura #, PO #, etc.
  description   String
  userId        String
  createdAt     DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@map("inventory_movements")
}

model PendingPayment {
  id          String   @id @default(uuid())
  clientId    String
  amount      Float
  description String?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  userId      String
  approvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([status])
  @@map("pending_payments")
}

model Warranty {
  id          String   @id @default(uuid())
  saleId      String?  @unique
  clientId    String?
  clientName  String
  clientRnc   String?
  clientPhone String?
  days        Int
  coverage    String?
  exclusions  String?
  issueDate   DateTime @default(now())
  expiryDate  DateTime
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sale      Sale?   @relation(fields: [saleId], references: [id], onDelete: SetNull)
  client    Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([clientId])
  @@index([issueDate])
  @@index([createdById])
  @@map("warranties")
}
